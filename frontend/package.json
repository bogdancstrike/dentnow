    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "antd": "^6.5.0",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.12",
    "keycloak-js": "^26.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ant-design/cli": "^6.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
