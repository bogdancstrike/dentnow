# DentNow Compose — NON-SECRET coordinates only.
#
# Copy to .env and adjust hostnames/ports. Secrets are NOT here: generate them with
#   ./ops/init-secrets.sh
# which writes mode-0600 files under ./.secrets/ consumed via Compose secrets.
# Startup refuses example/weak secrets, HTTP origins in production, and dev Keycloak
# mode in production.

# ── Environment: local | test | production ──────────────────────────────────
ENVIRONMENT=local

# ── Public browser origins (exact per deployment) ───────────────────────────
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_PREVIEW_URL=http://localhost:3001
PUBLIC_KEYCLOAK_URL=http://localhost:8080
# NOTE: PUBLIC_KEYCLOAK_URL must match KEYCLOAK_PORT (the browser-facing origin);
# it is also the token issuer the backend validates. Change both together.

# ── Local loopback port bindings ────────────────────────────────────────────
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
KEYCLOAK_PORT=8080
API_PORT=5100
FRONTEND_PORT=3000

# ── MinIO identities (non-secret names; passwords are secret files) ─────────
MINIO_ROOT_USER=dentnow-root
S3_ACCESS_KEY=dentnow-app

# ── Keycloak bootstrap admin username (password is a secret file) ───────────
KEYCLOAK_ADMIN_USER=admin

# ── Optional local dev admin (only used when BOTH are set; never in production)
# SEED_ADMIN_USERNAME=dentadmin
# SEED_ADMIN_PASSWORD=change-me-locally

# ── Optional deterministic E2E identities (disposable local/CI only) ────────
SEED_E2E_USERS=false

# ── Build identity (set by CI) ──────────────────────────────────────────────
BUILD_REVISION=dev
