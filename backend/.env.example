# Copy this file to backend/.env for local development.
# Values injected by the shell or container take precedence over this file.

# Application
SERVICE_NAME=dentnow-api
API_PORT=5100
ENVIRONMENT=local
LOG_LEVEL=INFO
BUILD_REVISION=dev
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://dentnow:dentnow@localhost:5432/dentnow
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# MinIO / S3
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=dentnow-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_PATH_STYLE=true

# Keycloak
KEYCLOAK_PUBLIC_URL=http://localhost:8090
KEYCLOAK_INTERNAL_URL=http://localhost:8090
KEYCLOAK_REALM=doncik
KEYCLOAK_ADMIN_CLIENT_ID=dentnow-api
KEYCLOAK_SPA_CLIENT_ID=dentnow-admin-spa
KEYCLOAK_AUDIENCE=dentnow-api
KEYCLOAK_AUTHORIZED_PARTY=dentnow-admin-spa
# Optional explicit overrides; normally derived from the URLs and realm above.
# KEYCLOAK_ISSUER=http://localhost:8090/realms/doncik
# KEYCLOAK_JWKS_URL=http://localhost:8090/realms/doncik/protocol/openid-connect/certs
JWKS_CACHE_TTL=3600
AUTH_DISABLED=false

# External services
GOOGLE_PLACES_API_KEY=

# Draft preview
PREVIEW_TOKEN_TTL_SECONDS=900
PREVIEW_TOKEN_PEPPER=change-me

# Tracing
ENABLE_TRACING=false
OTLP_ENDPOINT=http://localhost:4317

# Compatibility values required by qf's eager imports
WORKER_NAME=dentnow-workers
ERROR_TOPIC=dentnow-errors
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
SECRET_KEY=change-me
